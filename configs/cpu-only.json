{
  "_name": "CPU Only — No GPU required, lightweight models",
  "_vram": "0GB (CPU inference)",

  "embedder": {
    "model": "BAAI/bge-small-en-v1.5",
    "quantize": false,
    "batch_size": 32,
    "max_seq_length": 512
  },
  "reranker": {
    "model": "cross-encoder/ms-marco-MiniLM-L12-v2",
    "enabled": true,
    "top_k": 5
  },
  "nli": {
    "enabled": false
  },
  "consolidator": {
    "enabled": false
  },
  "chunker": {
    "chunk_size": 512,
    "overlap_ratio": 0.25,
    "min_section_tokens": 10
  },
  "search": {
    "fetch_multiplier": 4,
    "rerank_top_k": 5
  },
  "tiers": {
    "library": 0.90,
    "project": 0.93,
    "docs": 0.95,
    "research": 0.97,
    "archive": 1.10
  }
}
