{
  "_name": "GPU Minimal — RTX 3050/4050 8GB, small embedder + small reranker",
  "_vram": "~2GB used, ~6GB free",

  "embedder": {
    "model": "BAAI/bge-base-en-v1.5",
    "quantize": false,
    "batch_size": 16,
    "max_seq_length": 512
  },
  "reranker": {
    "model": "cross-encoder/ms-marco-MiniLM-L12-v2",
    "enabled": true,
    "top_k": 5
  },
  "nli": {
    "enabled": false
  },
  "consolidator": {
    "enabled": false
  },
  "chunker": {
    "chunk_size": 384,
    "overlap_ratio": 0.25,
    "min_section_tokens": 10
  },
  "search": {
    "fetch_multiplier": 3,
    "rerank_top_k": 5
  },
  "tiers": {
    "library": 0.90,
    "project": 0.93,
    "docs": 0.95,
    "research": 0.97,
    "archive": 1.10
  }
}
