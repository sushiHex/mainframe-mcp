{
  "_name": "GPU Light — RTX 3060/4060 12GB, embedder + reranker only",
  "_vram": "~10GB used, ~2GB free",

  "embedder": {
    "model": "Qwen/Qwen3-Embedding-8B",
    "quantize": true,
    "batch_size": 4,
    "max_seq_length": 4096
  },
  "reranker": {
    "model": "BAAI/bge-reranker-v2-m3",
    "enabled": true,
    "top_k": 5
  },
  "nli": {
    "enabled": false
  },
  "consolidator": {
    "enabled": false
  },
  "chunker": {
    "chunk_size": 256,
    "overlap_ratio": 0.35,
    "min_section_tokens": 10
  },
  "search": {
    "fetch_multiplier": 2,
    "rerank_top_k": 5
  },
  "tiers": {
    "library": 0.90,
    "project": 0.93,
    "docs": 0.95,
    "research": 0.97,
    "archive": 1.10
  }
}
